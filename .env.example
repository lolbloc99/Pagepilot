# AI Provider (required)
AI_PROVIDER=groq                    # groq | openrouter | ollama | custom
AI_API_KEY=your_api_key_here
AI_MODEL=llama-3.3-70b-versatile

# AI Fallback (optional — used when primary hits rate limits)
# AI_FALLBACK_PROVIDER=openrouter
# AI_FALLBACK_API_KEY=your_fallback_key
# AI_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct

# Custom AI endpoint (only for AI_PROVIDER=custom)
# AI_BASE_URL=https://your-endpoint.com/v1

# MongoDB (required)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=pagepilot

# Shopify API version (optional, defaults to 2025-01)
# SHOPIFY_API_VERSION=2025-01
